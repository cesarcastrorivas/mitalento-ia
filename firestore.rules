rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si es admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Función auxiliar para verificar si está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Colección: users
    // - Cada usuario solo puede leer su propio documento; admins pueden leer todos.
    // - Solo admins pueden crear/borrar usuarios (gestión de usuarios).
    // - El propio usuario puede actualizar su documento (progreso); admins pueden actualizar cualquiera.
    // NOTA: el leaderboard y reportes usan rutas API con Admin SDK que bypasean estas reglas.
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Colección: learning_paths
    // - Admin: Todo
    // - Usuario: Leer activos
    match /learning_paths/{pathId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Colección: courses
    // - Admin: Todo
    // - Usuario: Leer activos
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Colección: modules
    // - Admin: Todo
    // - Usuario: Leer activos
    match /modules/{moduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Colección: quiz_sessions
    // - Cualquier usuario autenticado puede leer (leaderboard necesita leer todas)
    // - Usuario puede crear sus sesiones (al terminar un quiz)
    match /quiz_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // No permitir editar sesiones pasadas para integridad, o solo admin
      allow update, delete: if isAdmin();
    }

    // Colección: knowledge_base
    // - Lectura pública: necesario para que el chat de SofIA/Bally lea el contexto sin sesión de usuario.
    // - Escritura: SOLO admins. Esta colección define el comportamiento de la IA; un write no autorizado
    //   podría inyectar contenido malicioso en las respuestas del chatbot (prompt injection indirecto).
    match /knowledge_base/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Evaluaciones actitudinales
    match /attitudinal_evaluations/{evalId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Planes de acción
    match /action_plans/{planId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Certificados (lectura pública para verificación QR)
    // - create: SOLO admin. Los certificados se generan exclusivamente desde la API del servidor
    //   usando Admin SDK. Un estudiante NO debe poder auto-emitirse un certificado.
    match /certificates/{certId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Compromisos firmados de estándares
    match /commitments/{commitId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
  }
}
