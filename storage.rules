rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Reglas existentes para videos (MANTENER)
    match /videos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // NUEVAS reglas para avatares de perfil (AGREGAR)
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      // El usuario puede subir su foto, O un administrador puede subirla en su nombre
      allow write: if request.auth != null && (
          request.auth.uid == userId || 
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Reglas para imágenes de portada de cursos
    match /course-thumbnails/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
